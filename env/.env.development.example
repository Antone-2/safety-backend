NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
FRONTEND_URL=http://localhost:5173
JWT_SECRET=replace-with-32-plus-character-dev-secret

POSTGRES_DB=safety_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/safety_backend
REDIS_URL=redis://redis:6379

REQUIRE_POSTGRES=false
REQUIRE_REDIS=false
CSRF_PROTECTION_ENABLED=false
SLOW_REQUEST_THRESHOLD_MS=2000

AUTH_OTP_TTL_MINUTES=10
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_OTP_REQUEST_WINDOW_MINUTES=15
AUTH_OTP_MAX_REQUESTS_PER_EMAIL=5
AUTH_OTP_MAX_REQUESTS_PER_IP=20
AUTH_OTP_MAX_REQUESTS_PER_DEVICE=10
AUTH_MAX_ACTIVE_SESSIONS_PER_USER=5

BACKUP_DIR=./backups
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
BACKUP_ENCRYPTION_KEY=
RESTORE_DRILL_DATABASE_URL=

BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Crown Paints Safety
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

ALLOWED_UPLOAD_MIME_TYPES=image/png,image/jpeg,image/webp,application/pdf,text/plain
MAX_UPLOAD_BYTES=10485760
