NODE_ENV=production
PORT=4000
LOG_LEVEL=info
FRONTEND_URL=https://ehs.example.com
JWT_SECRET=replace-with-secret-manager-value

POSTGRES_DB=safety_backend
POSTGRES_USER=safety_app
POSTGRES_PASSWORD=replace-with-secret-manager-value
DATABASE_URL=postgres://safety_app:replace-with-secret-manager-value@postgres:5432/safety_backend
REDIS_URL=redis://redis:6379

REQUIRE_POSTGRES=true
REQUIRE_REDIS=true
CSRF_PROTECTION_ENABLED=true
SLOW_REQUEST_THRESHOLD_MS=1000

AUTH_OTP_TTL_MINUTES=10
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_OTP_REQUEST_WINDOW_MINUTES=15
AUTH_OTP_MAX_REQUESTS_PER_EMAIL=4
AUTH_OTP_MAX_REQUESTS_PER_IP=12
AUTH_OTP_MAX_REQUESTS_PER_DEVICE=6
AUTH_MAX_ACTIVE_SESSIONS_PER_USER=3

BACKUP_DIR=/app/backups
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=90
BACKUP_ENCRYPTION_KEY=replace-with-secret-manager-value
RESTORE_DRILL_DATABASE_URL=postgres://safety_app:replace-with-secret-manager-value@postgres:5432/safety_restore_drill

S3_BUCKET=replace-with-backup-bucket
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=replace-with-secret-manager-value
S3_SECRET_ACCESS_KEY=replace-with-secret-manager-value

BREVO_API_KEY=replace-with-secret-manager-value
BREVO_SENDER_EMAIL=safety@crownpaints.co.ke
BREVO_SENDER_NAME=Crown Paints Safety
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

SENTRY_DSN=
ALLOWED_UPLOAD_MIME_TYPES=image/png,image/jpeg,image/webp,application/pdf,text/plain
MAX_UPLOAD_BYTES=10485760
