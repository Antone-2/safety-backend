NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# JWT - generates a random 64-char hex secret if not set (insecure, set for production!)
JWT_SECRET=

# Firebase (optional - falls back to SQLite if not configured)
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PROJECT_ID=

# Google Sheets integration
GOOGLE_FORM_ID=
GOOGLE_SHEET_NAME=Unsafe Acts/ Conditions (Responses)
GOOGLE_API_KEY=
GOOGLE_SHEETS_API_BASE_URL=
GOOGLE_SHEETS_BASE_URL=
GOOGLE_SHEETS_FALLBACK_URL=
GOOGLE_DOCS_EXPORT_BASE_URL=
GOOGLE_DOCS_BASE_URL=
GOOGLE_DOCS_FALLBACK_URL=
GOOGLE_PLACEHOLDER_IMAGE_URL=
PLACEHOLDER_IMAGE_URL=

# SMTP / Email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
DEFAULT_NOTIFICATION_EMAIL=

# Twilio / SMS
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Google OAuth (optional)
CLIENT_ID=
CLIENT_SECRET=

# Database (optional - defaults to ./data.db relative to module)
DATABASE_PATH=
