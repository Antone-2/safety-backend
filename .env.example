# Copy this file to .env and fill values. Do not commit real secrets.

NODE_ENV=development
PORT=4000
LOG_LEVEL=info
FRONTEND_URL=
JWT_SECRET=
DATABASE_URL=
REDIS_URL=
DATABASE_PATH=

# Firebase Admin credentials. Use one of these options:
# 1) FIREBASE_SERVICE_ACCOUNT as a single JSON string
# 2) FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY + FIREBASE_PROJECT_ID
# 3) GOOGLE_APPLICATION_CREDENTIALS as an absolute path outside this repository
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Google Sheets integration
GOOGLE_FORM_ID=
GOOGLE_SHEET_NAME=
GOOGLE_API_KEY=
# Use dmy for dates like 8/7/2026 = 8 July 2026. Use mdy only for US-style sheets.
GOOGLE_SHEETS_DATE_ORDER=dmy
GOOGLE_SHEETS_API_BASE_URL=
GOOGLE_SHEETS_BASE_URL=
GOOGLE_SHEETS_FALLBACK_URL=
GOOGLE_DOCS_EXPORT_BASE_URL=
GOOGLE_DOCS_BASE_URL=
GOOGLE_DOCS_FALLBACK_URL=
GOOGLE_DRIVE_DOWNLOAD_BASE_URL=
GOOGLE_PLACEHOLDER_IMAGE_URL=
PLACEHOLDER_IMAGE_URL=

# Storage
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# SMTP / Email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
DEFAULT_NOTIFICATION_EMAIL=
NOTIFICATION_FROM_EMAIL=
NOTIFICATION_TEAM_EMAILS=
NOTIFICATION_TEAM_PHONES=
NOTIFICATION_TEAM_WHATSAPP_NUMBERS=

# Twilio / SMS
TWILIO_SID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

# AI provider
AI_API_BASE_URL=
AI_MODEL=
OPENAI_API_KEY=
AI_API_KEY=

# Optional local demo login. Leave disabled unless all values are intentionally set.
ENABLE_DEMO_LOGIN=false
DEMO_EMAIL=
DEMO_PASSWORD=
DEMO_NAME=
DEMO_ROLE=
