# Crown Safety Backend — Environment Variables Template
# Copy this file to .env and fill in your production values.
# Never commit .env to version control.

# ------------------------------------------------------------------
# Core
# ------------------------------------------------------------------
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# ------------------------------------------------------------------
# Frontend / CORS
# ------------------------------------------------------------------
# Comma-separated allowed origins for CORS (e.g. https://app.example.com)
FRONTEND_URL=https://your-vercel-domain.vercel.app

# ------------------------------------------------------------------
# Security (REQUIRED in production)
# ------------------------------------------------------------------
# Must be at least 32 characters. Use a strong random string.
JWT_SECRET=replace-me-with-a-strong-random-secret-at-least-32-chars

# ------------------------------------------------------------------
# Database (REQUIRED in production)
# ------------------------------------------------------------------
# PostgreSQL connection string (Render, Supabase, AWS RDS, etc.)
DATABASE_URL=postgres://user:password@host:5432/safety_backend
# Optional legacy split config (used only if DATABASE_URL is not set)
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=safety_backend
REQUIRE_POSTGRES=true

# ------------------------------------------------------------------
# Redis (REQUIRED in production for rate limiting / jobs)
# ------------------------------------------------------------------
REDIS_URL=redis://host:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
REQUIRE_REDIS=true

# ------------------------------------------------------------------
# File Storage (S3-compatible) — optional but recommended
# ------------------------------------------------------------------
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_PUBLIC_URL=https://cdn.example.com

# ------------------------------------------------------------------
# Email / Notifications
# ------------------------------------------------------------------
# Brevo (preferred)
# BREVO_API_KEY=your-brevo-api-key
# BREVO_SENDER_EMAIL=no-reply@example.com
# BREVO_SENDER_NAME=Crown Safety

# SMTP fallback
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=user@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Crown Safety <no-reply@example.com>

# Notification recipients (comma-separated)
# NOTIFICATION_FROM_EMAIL=no-reply@example.com
# NOTIFICATION_TEAM_EMAILS=she@example.com,manager@example.com
# NOTIFICATION_TEAM_PHONES=+254700000000,+254700000001
# NOTIFICATION_TEAM_WHATSAPP_NUMBERS=whatsapp:+254700000000,whatsapp:+254700000001
# SHE_TEAM_EMAILS=she@example.com
# SHE_TEAM_PHONES=+254700000000
# SHE_TEAM_WHATSAPP_NUMBERS=whatsapp:+254700000000

# ------------------------------------------------------------------
# SMS (Twilio) — optional
# ------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_SMS_FROM=Crown Safety
# TWILIO_WHATSAPP_FROM=+254700000000
# Legacy aliases (also supported)
# TWILIO_SID=your-account-sid
# TWILIO_FROM=+254700000000

# ------------------------------------------------------------------
# Google Sheets Integration — optional
# ------------------------------------------------------------------
# GOOGLE_FORM_ID=your-spreadsheet-id
# GOOGLE_SHEET_NAME=Unsafe Acts/ Conditions (Responses)
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_DOCS_EXPORT_BASE_URL=https://docs.google.com
# GOOGLE_SHEETS_DATE_ORDER=dmy

# ------------------------------------------------------------------
# Error Tracking (Sentry) — optional
# ------------------------------------------------------------------
# SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ------------------------------------------------------------------
# AI / LLM — optional
# ------------------------------------------------------------------
# AI_API_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your-openai-key
# AI_API_KEY=your-ai-key

# ------------------------------------------------------------------
# Rate Limiting — optional overrides
# ------------------------------------------------------------------
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_SKIP_LOCALHOST=true

# ------------------------------------------------------------------
# Demo Login (development only) — disable in production
# ------------------------------------------------------------------
# ENABLE_DEMO_LOGIN=false
# DEMO_EMAIL=demo@example.com
# DEMO_PASSWORD=replace-me-with-a-strong-password-min-12-chars
# DEMO_NAME=Demo Administrator
# DEMO_ROLE=super-admin
