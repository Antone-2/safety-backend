# Copy this file to .env and fill values.
# The backend reads Firebase Admin credentials from one of:
#   1) FIREBASE_SERVICE_ACCOUNT (single JSON string), OR
#   2) FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY + FIREBASE_PROJECT_ID.
# Or (recommended for local dev): put firebase-service-account.json at
#   safety-backend/firebase-service-account.json

# --- Option 1: single env var (JSON string) ---
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account", "project_id":"...", ...}

# --- Option 2: separate env vars ---
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PROJECT_ID=

