{
  "name": "safety-backend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:migrate:dry": "tsx src/scripts/migrate.ts -- --dry-run",
    "db:migrate:backup": "tsx src/scripts/migrate.ts -- --backup-before",
    "db:import-sqlite": "tsx src/scripts/import-sqlite-to-postgres.ts",
    "db:backup": "tsx src/scripts/backup.ts",
    "db:restore": "tsx src/scripts/restore.ts",
    "db:restore:drill": "tsx src/scripts/backup-restore-drill.ts",
    "db:prune": "tsx src/scripts/prune-backups.ts",
    "ops:startup-check": "tsx src/scripts/startup-check.ts",
    "ops:startup-migrate": "tsx src/scripts/startup-check.ts --migrate",
    "workers": "tsx src/jobs/scheduler.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit --testTimeout=15000 --hookTimeout=15000",
    "test:integration": "vitest run tests/integration --testTimeout=15000 --hookTimeout=15000",
    "test:e2e": "vitest run tests/e2e --testTimeout=15000 --hookTimeout=15000",
    "test": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@opentelemetry/api": "^1.9.1",
    "@sentry/node": "^10.64.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.2",
    "@types/redis": "^4.0.11",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.52.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "pg": "^8.16.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "sharp": "^0.33.5",
    "sql.js": "^1.14.1",
    "twilio": "^5.6.0",
    "uuid": "^11.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^9.32.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
